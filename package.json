{
  "name": "overlap-db",
  "version": "0.1.0",
  "private": true,
  "description": "Backfill and snapshot utilities for Overlap user datasets.",
  "type": "module",
  "engines": {
    "node": ">=22.11.0"
  },
  "scripts": {
    "backfill:0.99": "node scripts/backfill-neynar-users.mjs --threshold 0.99",
    "export:cache": "node scripts/export-cache-snapshot.mjs --threshold 0.99",
    "tag:context:24h": "python3 scripts/enrich_fids_with_snapchain_context.py --hours 24",
    "tag:cohort:7d": "python3 scripts/enrich_fids_with_snapchain_context.py --hours 168 --skip-active-export",
    "rewrite:role-tags": "node scripts/rewrite-role-tag-datasets.mjs",
    "validate": "node scripts/validate-dataset.mjs",
    "query": "node scripts/query-users.mjs"
  }
}
